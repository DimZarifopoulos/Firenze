<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4EEDF">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/imgMonument"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/firenze_poster1"
                    android:contentDescription="Monument image" />

                <!-- Heart floating on image -->
                <ImageButton
                    android:id="@+id/btnHeart"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_icon_circle"
                    android:padding="12dp"
                    android:src="@drawable/ic_heart_outline"
                    android:tint="#B76F4B" />
            </FrameLayout>

            <!-- Bottom info sheet -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-22dp"
                android:background="@drawable/bg_bottom_sheet"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="24dp">


                <!-- Small category -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Featured Monument"
                    android:textColor="#B76F4B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Santa Maria del Fiore"
                    android:textColor="#20332F"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Description -->
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Ο καθεδρικός ναός της Φλωρεντίας είναι ένα από τα πιο εμβληματικά μνημεία της Ιταλίας, σύμβολο της Αναγέννησης και σημείο αναφοράς της πόλης."
                    android:textColor="#5E5A4C"
                    android:textSize="15sp" />

                <!-- Chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCategoryChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="Category"
                        android:textColor="#20332F"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Action buttons -->
                <Button
                    android:id="@+id/btnListen"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:backgroundTint="#365148"
                    android:text="Listen"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnLearnMore"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#B76F4B"
                    android:text="Learn more"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
                <Button
                    android:id="@+id/btnOpenMap"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#8A9A5B"
                    android:text="Open maps"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="#CFBD92"
                    android:text="Start quiz"
                    android:textAllCaps="false"
                    android:textColor="#20332F"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation -->
    <include layout="@layout/bottom_nav" />

</LinearLayout>